generator client {
  provider = "prisma-client-js"
}

// NextJS and Prisma with sqlite
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Screen {
  id        String   @id @default(cuid())
  name      String
  widgets   Widget[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Widget {
  id        String   @id @default(cuid())
  screenId  String
  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  type      String   // 'clock', 'weather', 'calendar', 'photos', 'quotes', 'tasks', 'text'
  x         Int
  y         Int
  w         Int
  h         Int
  config    String?  // JSON stringified configuration for the widget (e.g. { location: 'New York' })
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String   @id @default(cuid())
  listName  String   // e.g., 'John list', 'Doe List'
  title     String
  completed Boolean  @default(false)
  dueDate   String?  // optional date string like "JAN 9"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Chore {
  id          String   @id @default(cuid())
  title       String
  assignee    String
  dayOfWeek   String   @default("daily") // "daily" | "Sun" | "Mon" | "Tue" | "Wed" | "Thu" | "Fri" | "Sat"
  completedOn String?  // ISO date "2025-01-15" — set to today when checked, null when unchecked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Homework {
  id        String   @id @default(cuid())
  assignee  String
  subject   String
  title     String
  dueDate   String?  // e.g. "Apr 10"
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MealPlan {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  mealType  String   @default("dinner") // "breakfast" | "lunch" | "dinner"
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek, mealType])
}

